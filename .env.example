# Get your key from https://aistudio.google.com/apikey
# Copy this file to .env.local and fill in your key.
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Google OAuth for Classroom / Gmail / Drive (create in Google Cloud Console)
VITE_GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com

# Optional: Sentry (error monitoring). Get DSN from sentry.io.
VITE_SENTRY_DSN=

# Optional (Phase 3): Firebase threads + push (REST-based integration in this repo)
# Create a Firebase project, enable Google sign-in, and set Firestore rules appropriately.
VITE_FIREBASE_API_KEY=your_firebase_web_api_key
VITE_FIREBASE_PROJECT_ID=your_firebase_project_id

# --- Billing (Stripe) — server-side (node server.js / production host) ---
# Create products/prices in Stripe Dashboard; use a recurring price id.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PRICE_ID=price_...
# Optional: stripe listen --forward-to localhost:8080/api/billing/webhook
STRIPE_WEBHOOK_SECRET=whsec_...
# Browser URL for success/cancel redirects (e.g. http://localhost:5173 in dev with Vite proxy)
APP_ORIGIN=http://localhost:5173

# Optional: absolute billing API URL when the SPA is not same-origin as server.js
# (usually leave unset in production). For Vite dev, use the proxy and leave unset.
# VITE_BILLING_API_BASE=http://localhost:8080
