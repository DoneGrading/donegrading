# Get your key from https://aistudio.google.com/apikey
# Copy this file to .env.local and fill in your key.
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Optional (Phase 3): Firebase threads + push (REST-based integration in this repo)
# Create a Firebase project, enable Google sign-in, and set Firestore rules appropriately.
VITE_FIREBASE_API_KEY=your_firebase_web_api_key
VITE_FIREBASE_PROJECT_ID=your_firebase_project_id
